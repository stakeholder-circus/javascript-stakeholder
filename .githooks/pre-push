#!/bin/sh
set -eu
branch=$(git rev-parse --abbrev-ref HEAD)
case "$branch" in
  main|master)
    if [ "${ALLOW_DIRECT_PROTECTED_PUSH:-0}" != "1" ]; then
      cat >&2 <<'ERR'
pre-push rejected direct push to protected branch. Use a PR or set ALLOW_DIRECT_PROTECTED_PUSH=1 for bootstrap pushes.
ERR
      exit 1
    fi
    ;;
esac
exit 0
